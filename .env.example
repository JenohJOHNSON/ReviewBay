# Neon Postgres. Paste the connection string from the Neon console.
# It usually includes sslmode=require.
DATABASE_URL=

# OpenAI generation for the review chatbot. Dashboard summaries use local Python ML.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_REASONING_EFFORT=low

# Airbyte Cloud trial imports Apify-backed sources into Neon staging tables.
AIRBYTE_SOURCE_MAP=config/airbyte_sources.yml
AIRBYTE_IMPORT_LIMIT=500

# Apify is used by Airbyte Cloud for web/review sources. The Python worker keeps
# the free app-store sources running without Apify.
APIFY_TOKEN=
# APIFY_TOKENS=token_a,token_b

# Optional source tuning.
FETCH_LIMIT=50
POLL_INTERVAL_SECONDS=900
ONBOARD_LIMIT=50
LOCAL_SOURCES=app_store,google_play

# Optional app-store / Play-store overrides.
APP_STORE_COUNTRY=us
GOOGLE_PLAY_LANG=en
GOOGLE_PLAY_COUNTRY=us
# APP_STORE_ID_BLUE_BOTTLE_COFFEE=1440573734
# GOOGLE_PLAY_ID_BLUE_BOTTLE_COFFEE=com.example.app

# Optional password gate for public deployments.
AUTH_USER=
AUTH_PASS=

# Optional alerts.
ALERT_WEBHOOK_URL=
ALERT_MAX_PER_PASS=5
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=reviewbay@localhost
