# Neon Postgres. Paste the connection string from the Neon console.
# It usually includes sslmode=require.
DATABASE_URL=

# Claude generation for chat and dashboard insights.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# Apify is required for the web connector and Apify-backed sources.
APIFY_TOKEN=
# APIFY_TOKENS=token_a,token_b

# Optional source tuning.
FETCH_LIMIT=50
POLL_INTERVAL_SECONDS=900
ONBOARD_LIMIT=50

# Optional app-store / Play-store overrides.
APP_STORE_COUNTRY=us
GOOGLE_PLAY_LANG=en
GOOGLE_PLAY_COUNTRY=us
# APP_STORE_ID_BLUE_BOTTLE_COFFEE=1440573734
# GOOGLE_PLAY_ID_BLUE_BOTTLE_COFFEE=com.example.app

# Optional password gate for public deployments.
AUTH_USER=
AUTH_PASS=

# Optional alerts.
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=reviewbay@localhost
